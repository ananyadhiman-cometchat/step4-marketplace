# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mkt_db

# JWT
JWT_SECRET=changeme-use-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CometChat — server-side only (never expose to client).
# COMETCHAT_API_KEY must be a fullAccess REST API Key from Dashboard → API & Auth Keys.
# Leave empty to run without CometChat (login still works; cc_token returns "").
COMETCHAT_APP_ID=
COMETCHAT_API_KEY=
COMETCHAT_REGION=us

# App
APP_ENV=development
APP_PORT=8000
