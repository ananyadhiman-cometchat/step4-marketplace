# Backend API base URL (no trailing slash)
EXPO_PUBLIC_API_URL=http://localhost:8000/api

# CometChat — replace with values from app.cometchat.com
# Auth key is intentionally absent: the backend mints per-user auth tokens (production mode)
EXPO_PUBLIC_COMETCHAT_APP_ID=your_app_id_here
EXPO_PUBLIC_COMETCHAT_REGION=us
