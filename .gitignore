# Dependencies
node_modules/

# Native build outputs (regenerated by expo prebuild + gradle/xcode)
**/build/
.gradle/
android/.gradle/
android/app/build/
ios/build/
ios/Pods/
**/DerivedData/
.expo/
.kotlin/

# Web build output
.next/
web/.next/
out/

# Secrets — build-time creds are injected by the pipeline (see mobile.write_cometchat_env).
# Commit only the .example templates.
.env
!.env.example

# Pipeline / demo artifacts (not app source)
_demo/
_logs/
_reports/
pipeline-state/
test-results/

# Ad-hoc e2e scripts copied into web/ at runtime
web/_*.mjs

# Python
__pycache__/
*.pyc

# OS / misc
.DS_Store
*.log

# Python virtualenv
.venv/
venv/

# Stray root screenshots
/_marketplace.png
*.png
!mobile/**/*.png
!web/**/*.png
!backend/**/*.png
